# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — secrets never get committed.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Backend/background jobs only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic → console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs → elevenlabs.io → Profile → API Keys (Text to Speech access)
ELEVENLABS_API_KEY=
# Optional: defaults to "George" pre-made voice if unset
ELEVENLABS_VOICE_ID=

# Inngest (only needed for production; local dev works without)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
